{
  "name": "@vernostudio/template-generator",
  "version": "0.0.0",
  "description": "Verno Studio Template Generator: generate templates for Verno Studio projects.",
  "keywords": [
    "cli",
    "template-generator",
    "typescript",
    "vernostudio",
    "virtual-fs"
  ],
  "bugs": {
    "url": "https://github.com/verno-studio/website/issues"
  },
  "license": "MIT",
  "author": "Noppakorn Kaewsalabnil <hello@pungrumpy.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/verno-studio/website.git",
    "directory": "packages/template-generator"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./fs-writer": {
      "types": "./dist/fs-writer.d.mts",
      "import": "./dist/fs-writer.mjs",
      "default": "./dist/fs-writer.mjs"
    },
    "./template-reader": {
      "types": "./dist/template-reader.d.mts",
      "import": "./dist/template-reader.mjs",
      "default": "./dist/template-reader.mjs"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "generate:templates": "bun run scripts/generate-template-registry.ts",
    "prebuild": "bun run generate:templates",
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "bun run generate:templates && tsgo --noEmit",
    "test": "bun run generate:templates && bun test",
    "test:coverage": "bun run generate:templates && bun test --coverage"
  },
  "dependencies": {
    "better-result": "^2.8.2",
    "handlebars": "^4.7.8"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "@types/node": "^25",
    "@typescript/native-preview": "^7.0.0-dev.20260428.1",
    "@vernostudio/typescript-config": "workspace:*",
    "tsdown": "^0.21.10",
    "typescript": "^6"
  }
}
