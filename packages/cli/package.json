{
  "name": "verno",
  "version": "0.1.0",
  "private": true,
  "description": "Verno CLI: scaffold Next.js and Turborepo projects with shadcn and Ultracite.",
  "bin": {
    "@verno/cli": "./dist/index.mjs",
    "verno": "./dist/index.mjs",
    "vernostudio": "./dist/index.mjs"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "typecheck": "tsgo --noEmit",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@verno/template-generator": "workspace:*",
    "commander": "^14.0.3",
    "execa": "^9.6.1",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "@types/node": "^25",
    "@verno/typescript-config": "workspace:*",
    "tsdown": "^0.21.10",
    "typescript": "^6"
  }
}
