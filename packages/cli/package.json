{
  "name": "@vernostudio/cli",
  "version": "0.1.2",
  "description": "Verno Studio CLI: scaffold Next.js and Turborepo projects with shadcn and Ultracite.",
  "keywords": [
    "cli",
    "monorepo",
    "next.js",
    "shadcn",
    "turborepo",
    "ultracite",
    "vernostudio"
  ],
  "bugs": {
    "url": "https://github.com/verno-studio/website/issues"
  },
  "license": "MIT",
  "author": "Noppakorn Kaewsalabnil <hello@pungrumpy.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/verno-studio/website.git",
    "directory": "packages/cli"
  },
  "bin": {
    "verno": "./dist/index.mjs",
    "vernostudio": "./dist/index.mjs"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "typecheck": "tsgo --noEmit",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@clack/prompts": "^1.4.0",
    "commander": "^14.0.3",
    "execa": "^9.6.1",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.1",
    "@vernostudio/template-generator": "workspace:*",
    "@vernostudio/typescript-config": "workspace:*",
    "tsdown": "^0.22.0",
    "typescript": "^6"
  }
}
